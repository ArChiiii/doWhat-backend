# Database
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
DATABASE_URL=postgresql://postgres:password@db.supabase.co:5432/postgres

# Redis
REDIS_URL=redis://localhost:6379

# JWT Authentication
JWT_SECRET_KEY=your-secret-key-generate-with-openssl-rand-hex-32
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30

# Third-Party APIs
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

GOOGLE_MAPS_API_KEY=your-google-maps-key

EVENTBRITE_API_KEY=your-eventbrite-key

OPENAI_API_KEY=sk-proj-your-openai-key

MIXPANEL_TOKEN=your-mixpanel-token

SENTRY_DSN=https://your-dsn@sentry.io/project-id

# App Configuration
ENVIRONMENT=development
DEBUG=true
CORS_ORIGINS=capacitor://localhost,http://localhost,https://dowhat.hk
RATE_LIMIT_PER_MINUTE=100

# Scraper Configuration
SCRAPER_RUN_INTERVAL_HOURS=6
SCRAPER_MAX_EVENTS_PER_RUN=50
SCRAPER_REQUEST_DELAY_SECONDS=2

# Cache Configuration
CACHE_EVENT_FEED_TTL_SECONDS=300
CACHE_USER_PREFERENCES_TTL_SECONDS=3600
CACHE_EVENT_DETAILS_TTL_SECONDS=600

# Worker Configuration
RQ_WORKER_COUNT=1
RQ_QUEUE_NAMES=scrapers,cleanup

