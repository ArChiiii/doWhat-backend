FROM python:3.12-slim

WORKDIR /app

# Install ONLY curl (for healthcheck if needed)
RUN apt-get update && apt-get install -y --no-install-recommends \
    curl \
    && rm -rf /var/lib/apt/lists/*

# Install Python dependencies
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# Install development dependencies
RUN pip install --no-cache-dir \
    debugpy==1.8.7 \
    ipython==8.28.0 \
    watchfiles==0.24.0

# Copy application code
COPY . .

# Expose port and debugger port
EXPOSE 8000 5678

# Development server with auto-reload
# Exclude tests directory from watchfiles to avoid WSL2 I/O errors
CMD ["uvicorn", "app.main:app", "--host", "0.0.0.0", "--port", "8000", "--reload", "--reload-dir", "./app", "--reload-exclude", "**/__pycache__/**", "--reload-exclude", "**/tests/**"]

